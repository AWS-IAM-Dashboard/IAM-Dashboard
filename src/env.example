# Environment Variables for IAM Dashboard

# AWS API Gateway URL
# This is the base URL for the API Gateway that connects to Lambda
VITE_API_GATEWAY_URL=https://erh3a09d7l.execute-api.us-east-1.amazonaws.com/v1

# Cognito (OAuth / Hosted UI)
# VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXX
# VITE_COGNITO_CLIENT_ID=your_app_client_id
# VITE_COGNITO_REDIRECT_URI=https://d84l1y8p4kdic.cloudfront.net
# For local dev, use: VITE_COGNITO_REDIRECT_URI=http://localhost:5173
# Hosted UI domain for logout (Cognito App integration → Domain name)
# VITE_COGNITO_DOMAIN=https://us-east-1h7e0irb5v.auth.us-east-1.amazoncognito.com
# Where to redirect after logout (must be in Cognito app client Sign-out URLs)
# VITE_COGNITO_LOGOUT_URI=https://d84l1y8p4kdic.cloudfront.net

# Backend API URL (for local Python backend if needed)
# VITE_API_URL=http://localhost:8000/api

# Optional: Enable debug logging
# VITE_DEBUG=true
{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Deny",
			"Action": [
				"lambda:DeleteFunction",
				"lambda:DeleteAlias",
				"lambda:DeleteEventSourceMapping",
				"lambda:DeleteFunctionConcurrency",
				"lambda:DeleteLayerVersion",
				"s3:DeleteBucket",
				"s3:DeleteBucketPolicy",
				"s3:DeleteBucketWebsite",
				"dynamodb:DeleteTable",
				"dynamodb:DeleteBackup",
				"apigateway:DELETE",
				"cloudfront:DeleteDistribution",
				"cloudfront:DeleteCloudFrontOriginAccessIdentity",
				"iam:DeleteRole",
				"iam:DeleteRolePolicy",
				"iam:DetachRolePolicy"
			],
			"Resource": "*",
			"Sid": "DenyInfrastructureDeletion"
		},
		{
			"Action": [
				"lambda:*"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:lambda:us-east-1:562559071105:function:iam-dashboard-scanner",
				"arn:aws:lambda:us-east-1:562559071105:function:iam-dashboard-scanner:*",
				"arn:aws:lambda:us-east-1:562559071105:function:iam-dashboard-*"
			],
			"Sid": "LambdaFull"
		},
		{
			"Action": [
				"apigateway:*"
			],
			"Effect": "Allow",
			"Resource": "*",
			"Sid": "APIGatewayFull"
		},
		{
			"Action": [
				"s3:*"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:s3:::iam-dashboard-project",
				"arn:aws:s3:::iam-dashboard-project/*",
				"arn:aws:s3:::iam-dashboard-scan-results",
				"arn:aws:s3:::iam-dashboard-scan-results/*"
			],
			"Sid": "S3Full"
		},
		{
			"Action": [
				"dynamodb:*"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:dynamodb:us-east-1:562559071105:table/iam-dashboard-scan-results",
				"arn:aws:dynamodb:us-east-1:562559071105:table/iam-dashboard-scan-results/index/*"
			],
			"Sid": "DynamoDBFull"
		},
		{
			"Action": [
				"cloudfront:*"
			],
			"Effect": "Allow",
			"Resource": "*",
			"Sid": "CloudFrontFull"
		},
		{
			"Action": [
				"iam:GetRole",
				"iam:PassRole",
				"iam:ListRoles",
				"iam:ListAttachedRolePolicies"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:iam::562559071105:role/iam-dashboard-*"
			],
			"Sid": "IAMPassRoleAndRead"
		},
		{
			"Action": [
				"iam:ListRolePolicies",
				"iam:GetRolePolicy"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:iam::562559071105:role/iam-dashboard-lambda-role"
			],
			"Sid": "TerraformImportLambdaDeploy"
		},
		{
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:DeleteObject",
				"s3:ListBucket"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:s3:::iam-dashboard-project",
				"arn:aws:s3:::iam-dashboard-project/terraform/*"
			],
			"Sid": "TerraformState"
		},
		{
			"Action": [
				"s3:ListBucket",
				"s3:GetObject",
				"s3:PutObject"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:s3:::iam-dashboard-terraform-state",
				"arn:aws:s3:::iam-dashboard-terraform-state/*"
			],
			"Sid": "TerraformStateBucket"
		},
		{
			"Action": [
				"cognito-idp:DescribeUserPool",
				"cognito-idp:ListUserPools",
				"cognito-idp:DescribeUserPoolClient",
				"cognito-idp:ListUserPoolClients"
			],
			"Effect": "Allow",
			"Resource": "*",
			"Sid": "CognitoReadForTerraform"
		},
		{
			"Action": [
				"sts:GetCallerIdentity",
				"iam:GetAccountSummary",
				"apigateway:GET",
				"cloudfront:ListDistributions",
				"cloudfront:ListCloudFrontOriginAccessIdentities",
				"dynamodb:ListTables",
				"s3:ListAllMyBuckets",
				"lambda:ListFunctions",
				"support:*",
				"trustedadvisor:*"
			],
			"Effect": "Allow",
			"Resource": "*",
			"Sid": "ConsoleNavigation"
		},
		{
			"Action": [
				"s3:ListBucket",
				"s3:GetObject"
			],
			"Effect": "Allow",
			"Resource": [
				"arn:aws:s3:::iam-dashboard-project-access-logs",
				"arn:aws:s3:::iam-dashboard-project-access-logs/*"
			],
			"Sid": "AccessLogsRead"
		}
	]
}
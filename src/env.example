# Environment Variables for IAM Dashboard

# AWS API Gateway URL
# This is the base URL for the API Gateway that connects to Lambda (cloud/prod/dev)
VITE_API_GATEWAY_URL=https://erh3a09d7l.execute-api.us-east-1.amazonaws.com/v1

# Backend API URL (for local Python backend in Docker)
# When running the local Lambda adapter on localhost:5001 with prefix /v1, use:
VITE_API_URL=http://localhost:5001/v1

# Optional: Enable debug logging
# VITE_DEBUG=true

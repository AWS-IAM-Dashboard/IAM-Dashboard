# Environment Configuration for Cybersecurity Dashboard

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@db:5432/cybersecurity_db
REDIS_URL=redis://redis:6379/0

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Frontend API Configuration
# AWS API Gateway URL
# This is the base URL for the API Gateway that connects to Lambda (cloud/prod/dev)
VITE_API_GATEWAY_URL=https://erh3a09d7l.execute-api.us-east-1.amazonaws.com/v1

# Backend API URL (for local Python backend in Docker)
# When running the local Lambda adapter on localhost:5001 with prefix /v1, use:
VITE_API_URL=http://localhost:5001/v1

# SMTP Configuration (local test defaults)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@local.test

# Grafana Configuration
GRAFANA_URL=http://grafana:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# Prometheus Configuration
PROMETHEUS_URL=http://prometheus:9090

# Security Configuration
JWT_SECRET_KEY=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
